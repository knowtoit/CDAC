package com.demo.sorting;

import java.util.Arrays;

public class HeapSortAlgorithm {
	public static void HeapSortAscending(int[] arr) {
		//convert tree into heap
		for(int i= (arr.length/2)-1; i>=0; i--) {
			heapify(arr, arr.length,i);
		}
		
		int n = arr.length;
		for(int i=n-1; i>=0; i--) {
			//swap the topmost value with the last value in array
			int temp = arr[i];
			arr[i] = arr[0];
			arr[0] = temp;
			//reconvert the tree into heap by using heapify
			heapify(arr,i,0);
		}
	}

	private static void heapify(int[] arr, int length, int i) {
		// TODO Auto-generated method stub
		//calculate left and right index position
		int left = 2*i +1;
		int right = 2 * i +2;
		int largest = i;
		
		//check whether left is within limit and is largest 
		if(left < length && arr[left]>arr[largest]) {
			largest = left;
		}
		
		//check whether right is within limit and is largest
		if(right < length && arr[right] > arr[largest]) {
			largest = right;
		}
		
		//if right or left is greater than largest then swap them
		//if largest is either left or right child then swap with parent
		if(largest !=i) {
			int temp = arr[i];
			arr[i] = arr[largest];
			arr[largest] = arr[temp];
			
			//heapify the tree
			heapify(arr,length, largest);
		}
		System.out.println(Arrays.toString(arr));
		System.out.println("---------------------------");
		
	}
}
